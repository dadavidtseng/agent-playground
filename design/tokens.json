{
  "name": "kadi-character-card-tokens",
  "version": "1.0.0",
  "breakpoints": {
    "bp-mobile": "0px",
    "bp-mobile-max": "480px",
    "bp-tablet-min": "481px",
    "bp-tablet-max": "1024px",
    "bp-desktop-min": "1025px"
  },
  "spacing": {
    "spacing-1": "4px",
    "spacing-2": "8px",
    "spacing-3": "12px",
    "spacing-4": "16px",
    "spacing-5": "20px",
    "spacing-6": "24px",
    "spacing-8": "32px",
    "spacing-10": "40px",
    "spacing-12": "48px"
  },
  "typography": {
    "font-family-base": "Inter, ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial",
    "font-weight-regular": "400",
    "font-weight-medium": "500",
    "font-weight-semibold": "600",

    "type-heading-xl": { "font-size": "20px", "line-height": "1.2", "font-weight": "600" },
    "type-heading-md": { "font-size": "16px", "line-height": "1.25", "font-weight": "600" },
    "type-body-md": { "font-size": "14px", "line-height": "1.4", "font-weight": "400" },
    "type-body-sm": { "font-size": "12px", "line-height": "1.3", "font-weight": "500" },

    "responsive-overrides": {
      "mobile": {
        "type-heading-xl": { "font-size": "18px" },
        "type-heading-md": { "font-size": "14px" },
        "type-body-md": { "font-size": "13px" }
      },
      "desktop": {
        "type-heading-xl": { "font-size": "22px" }
      }
    }
  },
  "colors": {
    "background": "#FFFFFF",
    "surface": "#F7FAFC",
    "text-primary": "#0B1F3B",
    "text-secondary": "#526476",
    "border": "#E6EDF3",
    "interactive-primary": "#2B8AF6",
    "interactive-primary-600": "#176FE6",
    "success": "#2ECC71",
    "danger": "#E24B4B",
    "disabled": "#A3B1BC",
    "white": "#FFFFFF",
    "black": "#000000"
  },
  "elevation": {
    "card-shadow-default": "0 1px 0 rgba(11,31,59,0.03)",
    "card-shadow-hover": "0 6px 20px rgba(11,31,59,0.08)"
  },
  "interaction": {
    "focus-ring": "0 0 0 3px rgba(43,138,246,0.16)",
    "hover-translate-y": "-2px",
    "active-scale": "0.98",
    "disabled-opacity": "0.64"
  },
  "motion": {
    "duration-fast": "120ms",
    "duration-medium": "200ms",
    "duration-long": "320ms",
    "easing-standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "easing-decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1)"
  },
  "avatar": {
    "avatar-xs": "28px",
    "avatar-sm": "40px",
    "avatar-md": "56px",
    "avatar-lg": "72px",
    "avatar-xl": "120px",
    "mask-square-radius": "0",
    "mask-rounded-radius": "8px",
    "mask-circle-radius": "50%",
    "pixel-art-image-rendering": "pixelated"
  },
  "misc": {
    "min-touch-target": "44px"
  }
}
