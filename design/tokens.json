{
  "$schema": "https://json.schemastore.org/design-tokens.json",
  "name": "kadi-design-tokens",
  "version": "1.0.0",
  "colors": {
    "light": {
      "--color-primary-50": "#EAF2FF",
      "--color-primary-100": "#CFE6FF",
      "--color-primary-300": "#66A9FF",
      "--color-primary-500": "#0B5FFF",
      "--color-primary-700": "#084BB2",
      "--color-primary-900": "#032963",

      "--color-background": "#FFFFFF",
      "--color-surface": "#F7F9FC",
      "--color-text": "#0F1724",
      "--color-muted": "#6B7280",

      "--color-danger-500": "#E03131",
      "--color-success-500": "#16A34A",
      "--color-warning-500": "#D97706"
    },
    "dark": {
      "--color-primary-50": "#0B2B4A",
      "--color-primary-100": "#0E3A6F",
      "--color-primary-300": "#2565B8",
      "--color-primary-500": "#4DA0FF",
      "--color-primary-700": "#7EC6FF",
      "--color-primary-900": "#BEE9FF",

      "--color-background": "#0B0F14",
      "--color-surface": "#0F1720",
      "--color-text": "#E6EEF6",
      "--color-muted": "#9AA6B2",

      "--color-danger-500": "#FF6B6B",
      "--color-success-500": "#5FE08A",
      "--color-warning-500": "#FFB454"
    }
  },
  "typography": {
    "--type-xs": {
      "fontSize": "12px",
      "lineHeight": "16px",
      "fontWeight": "400",
      "description": "Caption / extra-small text"
    },
    "--type-sm": {
      "fontSize": "14px",
      "lineHeight": "20px",
      "fontWeight": "400",
      "description": "Small body text"
    },
    "--type-md": {
      "fontSize": "16px",
      "lineHeight": "24px",
      "fontWeight": "400",
      "description": "Base body text"
    },
    "--type-lg": {
      "fontSize": "18px",
      "lineHeight": "28px",
      "fontWeight": "600",
      "description": "Subheading / strong body"
    },
    "--type-xl": {
      "fontSize": "20px",
      "lineHeight": "28px",
      "fontWeight": "700",
      "description": "Heading level 3"
    },
    "--type-xxl": {
      "fontSize": "28px",
      "lineHeight": "36px",
      "fontWeight": "700",
      "description": "Heading level 1 / page title"
    }
  },
  "breakpoints": {
    "--breakpoint-mobile": "480px",
    "--breakpoint-tablet": "768px",
    "--breakpoint-desktop": "1024px",
    "values": {
      "mobile": "480px",
      "tablet": "768px",
      "desktop": "1024px"
    }
  },
  "motion": {
    "--motion-duration-fast": "150ms",
    "--motion-duration-medium": "300ms",
    "--motion-duration-slow": "500ms",
    "--motion-ease-standard": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "--motion-ease-decelerate": "cubic-bezier(0.0, 0.0, 0.2, 1)",
    "--motion-ease-accelerate": "cubic-bezier(0.4, 0.0, 1, 1)"
  },
  "metadata": {
    "generatedBy": "designer-agent (KĀDI)",
    "sourceSpec": "./spec.md",
    "notes": "Tokens include both light and dark variants for color. CSS variable names are provided as keys. Use them directly in CSS or import the JSON in build tooling."
  }
}
