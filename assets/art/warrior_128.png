<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" width="128" height="128" viewBox="0 0 128 128" shape-rendering="crispEdges">
  <!-- 16x16 pixel art scaled to 128x128 (pixel size = 8) -->
  <!-- Palette:
       skin: #F5C6A5
       hair: #2B1B0B
       armor: #B0C4C9
       blade: #E8E8E8
       hilt: #6B4A2C
       shield wood: #8A4B2B
       cloak: #7B1F1F
       boots: #3B2A1A
       outline: #000000
  -->
  <rect width="100%" height="100%" fill="none" />

  <!-- Hair (dark) -->
  <rect x="48" y="16" width="32" height="8" fill="#2B1B0B" />
  <rect x="40" y="24" width="8" height="8" fill="#2B1B0B" />
  <rect x="88" y="24" width="8" height="8" fill="#2B1B0B" />

  <!-- Face / skin -->
  <rect x="48" y="24" width="32" height="16" fill="#F5C6A5" />

  <!-- Helmet/shoulder (armor) -->
  <rect x="40" y="40" width="48" height="16" fill="#B0C4C9" />
  <rect x="40" y="56" width="48" height="32" fill="#B0C4C9" />

  <!-- Cloak (back) -->
  <rect x="56" y="40" width="16" height="56" fill="#7B1F1F" opacity="0.95" />

  <!-- Left arm (holding shield) -->
  <rect x="40" y="48" width="8" height="16" fill="#B0C4C9" />
  <rect x="48" y="48" width="8" height="8" fill="#B0C4C9" />

  <!-- Right arm (holding sword) -->
  <rect x="88" y="48" width="8" height="16" fill="#B0C4C9" />
  <rect x="80" y="56" width="8" height="8" fill="#B0C4C9" />

  <!-- Shield (wooden) -->
  <rect x="16" y="48" width="24" height="40" fill="#8A4B2B" />
  <rect x="28" y="56" width="8" height="24" fill="#6B4A2C" opacity="0.8" />

  <!-- Sword blade -->
  <rect x="96" y="24" width="8" height="56" fill="#E8E8E8" />
  <rect x="96" y="16" width="8" height="8" fill="#E8E8E8" />
  <!-- Sword hilt -->
  <rect x="88" y="80" width="16" height="8" fill="#6B4A2C" />

  <!-- Boots -->
  <rect x="48" y="88" width="16" height="24" fill="#3B2A1A" />
  <rect x="64" y="88" width="16" height="24" fill="#3B2A1A" />

  <!-- Simple outline accents -->
  <rect x="40" y="40" width="8" height="8" fill="#000000" opacity="0.25" />
  <rect x="80" y="40" width="8" height="8" fill="#000000" opacity="0.25" />

</svg>