# model.obj
# Created by artist agent (no Blender available).
# This OBJ approximates a sphere (octahedron) centered at (0,0,1) and a plane at z=0.
# Transforms applied: vertices are in final world positions. Normals are provided (vn lines).
# Materials: plane intended dark gray #2f2f2f, sphere intended orange #ff8c00 (not embedded here).

# Plane (quad) vertices
v -2.0 -2.0 0.0
v  2.0 -2.0 0.0
v  2.0  2.0 0.0
v -2.0  2.0 0.0

# Plane normals (pointing up)
vn 0.0 0.0 1.0

# Sphere (octahedron) vertices centered at (0,0,1) with radius 0.5
v  0.0  0.0 1.5    # top
v  0.5  0.0 1.0
v  0.0  0.5 1.0
v -0.5  0.0 1.0
v  0.0 -0.5 1.0
v  0.0  0.0 0.5    # bottom

# Normals for sphere vertices (normalized relative to center)
# top vertex normal
vn 0.0 0.0 1.0
# ring normals (approx)
vn 0.7071 0.0 0.7071
vn 0.0 0.7071 0.7071
vn -0.7071 0.0 0.7071
vn 0.0 -0.7071 0.7071
# bottom normal
vn 0.0 0.0 -1.0

# Faces: plane (use normal 1 for all)
usemtl PlaneMaterial
f 1//1 2//1 3//1 4//1

# Faces: octahedron (triangles) referencing vertex//normal
usemtl SphereMaterial
f 7//1 2//2 3//3
f 7//1 3//3 4//4
f 7//1 4//4 5//5
f 7//1 5//5 2//2

f 6//6 3//3 2//2
f 6//6 4//4 3//3
f 6//6 5//5 4//4
f 6//6 2//2 5//5

# End of file
