<?xml version="1.0" encoding="UTF-8"?>
<!-- Cartoon-style dog illustration encoded as SVG (pixel-grid using <rect>).
     Named .png but contains SVG XML per system limitations. Intended size: 2048x2048, transparent background. -->
<svg xmlns="http://www.w3.org/2000/svg" width="2048" height="2048" viewBox="0 0 64 64" shape-rendering="crispEdges">
  <!-- Palette: #FFC966 (yellow), #FF8A00 (orange), #6B3B00 (dark), #FFFFFF, #000000 -->
  <!-- Exaggerated shapes, bold colors -->
  <rect x="12" y="14" width="40" height="34" fill="#FFC966" />
  <rect x="8" y="8" width="12" height="12" fill="#FF8A00" />
  <rect x="44" y="8" width="12" height="12" fill="#FF8A00" />
  <!-- Large expressive eyes -->
  <rect x="22" y="22" width="6" height="6" fill="#000000" />
  <rect x="36" y="22" width="6" height="6" fill="#000000" />
  <rect x="24" y="24" width="2" height="2" fill="#FFFFFF" />
  <rect x="38" y="24" width="2" height="2" fill="#FFFFFF" />
  <!-- Big smile -->
  <rect x="24" y="34" width="16" height="4" fill="#6B3B00" />
  <!-- Tongue -->
  <rect x="30" y="36" width="4" height="3" fill="#FF8A00" />
  <!-- Collar -->
  <rect x="18" y="42" width="28" height="5" fill="#FF8A00" />
  <rect x="30" y="44" width="4" height="4" fill="#6B3B00" />
</svg>