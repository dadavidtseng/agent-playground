# pedestal_display.obj
# Simple low-poly scene: plane + octahedron "sphere" centered at (0,0,1)
mtllib pedestal_display.mtl

# Plane (quad) at Z=0
v -1 -1 0
v 1 -1 0
v 1 1 0
v -1 1 0

# Octahedron approximating a sphere centered at (0,0,1)
v 0 0 2
v 1 0 1
v 0 1 1
v -1 0 1
v 0 -1 1
v 0 0 0

# Normals (approximate per-vertex normals)
vn 0 0 1
vn 0 0 1
vn 0 0 1
vn 0 0 1
vn 0 0 1
vn 0 0 -1

# Use material for plane
usemtl plane_mat
s off
f 1//1 2//1 3//1 4//1

# Use material for sphere (octahedron)
usemtl sphere_mat
s off
# Faces: top to equator
f 5//1 6//2 7//3
f 5//1 7//3 8//4
f 5//1 8//4 9//5
f 5//1 9//5 6//2
# Faces: bottom to equator
f 10//6 7//3 6//2
f 10//6 8//4 7//3
f 10//6 9//5 8//4
f 10//6 6//2 9//5
