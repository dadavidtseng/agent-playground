{
  "name": "agent-playground-programmer",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "optimize:svgo": "svgo -f art -o art --multipass --config=svgo.config.js",
    "minify:css": "cleancss -o demo/styles.min.css demo/styles.css",
    "minify:js": "terser demo/scripts.js -o demo/scripts.min.js --compress --mangle",
    "build:zip": "zip -r dist/project-deliverables.zip design art demo qa README.md"
  },
  "devDependencies": {
    "svgo": "^3.0.0",
    "clean-css-cli": "^6.0.0",
    "terser": "^5.0.0"
  }
}